{
  "name": "pokemon-emerald-flow-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:format": "prettier --write \"src/lib/generated/**/*.{ts,tsx}\"",
    "gen:sprites:b64": "tsx scripts/gen-sprites-b64.ts",
    "gen:gallery": "tsx scripts/gen-gallery.ts",
    "up:gallery": "tsx scripts/up-gallery.ts",
    "gen:placeholders": "tsx scripts/gen-placeholders.ts",
    "gen:placeholders:b64": "tsx scripts/gen-placeholders-b64.ts",
    "prebuild": "pnpm gen:sprites:b64 && pnpm gen:gallery && pnpm up:gallery && pnpm gen:placeholders && pnpm gen:placeholders:b64 && pnpm gen:format",
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx}\" --cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^1.20.0",
    "next": "^15.2.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-swipeable": "^7.0.2",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/env": "^16.2.10",
    "@tailwindcss/postcss": "^4.0.15",
    "@tailwindcss/typography": "^0.5.20",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/blob": "^2.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@10.15.0"
}
